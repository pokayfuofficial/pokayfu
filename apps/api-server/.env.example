# ─────────────────────────────────────────────
#  POKAYFU API — Environment Variables
#  Скопируй в .env и заполни реальными значениями
# ─────────────────────────────────────────────

# ── APP ────────────────────────────────────────
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── DATABASE ───────────────────────────────────
DATABASE_URL=postgresql://pokayfu:pokayfu_pass@localhost:5432/pokayfu_db

# ── REDIS ──────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ────────────────────────────────────────
JWT_SECRET=change_me_to_256_bit_random_string_in_production
JWT_REFRESH_SECRET=change_me_too_different_from_jwt_secret

# ── TELEGRAM ───────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# ── STORAGE (Cloudflare R2 / MinIO) ────────────
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=pokayfu-media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_PUBLIC_URL=http://localhost:9000/pokayfu-media

# ── TON BLOCKCHAIN ─────────────────────────────
TON_ENDPOINT=https://testnet.toncenter.com/api/v2
TON_API_KEY=your_ton_api_key
TON_MNEMONIC=word1 word2 word3 ... word24
PLATFORM_WALLET_ADDRESS=EQyour_platform_wallet_address

# ── STON.FI ────────────────────────────────────
STONFI_ROUTER_ADDRESS=EQstonfi_router_address
LIQUIDITY_LOCK_ADDRESS=EQliquidity_lock_contract_address

# ── EXTERNAL APIs ──────────────────────────────
COINGECKO_API_KEY=your_coingecko_api_key
